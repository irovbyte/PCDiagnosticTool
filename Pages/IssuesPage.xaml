<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PCDiagnosticTool.Pages.IssuesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="12">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Журнал и Умная Починка" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Журнал системных событий Windows за последние 24 часа. Проверьте систему на наличие критических предупреждений и запустите встроенные инструменты починки в один клик."
                TextWrapping="Wrap" />

            <StackPanel
                Margin="0,8,0,0"
                Orientation="Horizontal"
                Spacing="16">
                <Button
                    x:Name="BtnAutoRepair"
                    Padding="16,8"
                    Click="BtnAutoRepair_ClickAsync"
                    Content="Запустить умный анализ и починку"
                    Style="{StaticResource AccentButtonStyle}" />
                <Button
                    x:Name="BtnFixSfc"
                    Click="BtnFixSfc_ClickAsync"
                    Content="SFC Сканирование" />
                <Button
                    x:Name="BtnFixDism"
                    Click="BtnFixDism_ClickAsync"
                    Content="DISM Восстановление" />
                <ProgressRing
                    x:Name="AutoRepairProgress"
                    IsActive="False"
                    Visibility="Collapsed" />
                <ProgressRing
                    x:Name="ManualRepairProgress"
                    IsActive="False"
                    Visibility="Collapsed" />
            </StackPanel>
        </StackPanel>

        <Grid
            Grid.Row="1"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <ListView x:Name="CrashList" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="16,12" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Ellipse
                                Width="12"
                                Height="12"
                                Margin="0,4,0,0"
                                VerticalAlignment="Top"
                                Fill="{Binding StatusBrush}" />

                            <StackPanel Grid.Column="1" Orientation="Vertical">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{Binding StatusBrush}"
                                        Text="{Binding LevelName}" />
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{Binding Source}" />
                                    <TextBlock
                                        FontSize="14"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        Text="{Binding TimeCreated}" />
                                </StackPanel>
                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{Binding Description}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel
                x:Name="LoadingPanel"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="16"
                Visibility="Collapsed">
                <ProgressRing
                    Width="48"
                    Height="48"
                    IsActive="True" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Сканирование системы на ошибки..." />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock
                Margin="0,0,0,8"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Text="Живой лог процесса починки:" />
            <TextBox
                x:Name="TxtRepairLog"
                Grid.Row="1"
                AcceptsReturn="True"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                FontFamily="Consolas"
                IsReadOnly="True"
                TextWrapping="Wrap" />
        </Grid>
    </Grid>
</Page>
